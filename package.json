{
  "name": "create-studio-monorepo",
  "private": true,
  "type": "module",
  "version": "0.0.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@create-studio/app",
    "dev:widgets": "npm run dev --workspace=@create-studio/widgets",
    "dev:docs": "npm run dev --workspace=@create-studio/docs",
    "dev:admin": "npm run dev --workspace=@create-studio/admin",
    "build": "npm run build --workspace=@create-studio/shared && npm run build --workspace=@create-studio/widgets && npm run build --workspace=@create-studio/app",
    "build:shared": "npm run build --workspace=@create-studio/shared",
    "build:widgets": "npm run build --workspace=@create-studio/widgets",
    "build:app": "npm run build --workspace=@create-studio/app",
    "build:admin": "npm run build --workspace=@create-studio/admin",
    "build:app:preview": "npm run build:shared && npm run build:app",
    "build:app:production": "npm run build:shared && npm run build:app",
    "deploy:app:preview": "npx wrangler deploy --config packages/app/wrangler.jsonc --env preview",
    "deploy:app:production": "npx wrangler deploy --config packages/app/wrangler.jsonc",
    "build:docs": "npm run build --workspace=@create-studio/docs",
    "generate:webhook-keys": "node scripts/generate-webhook-keys.js",
    "seed:admin": "npx tsx scripts/seed-admin.ts",
    "test": "npm run test --workspaces",
    "test:shared": "npm run test --workspace=@create-studio/shared",
    "test:widgets": "npm run test --workspace=@create-studio/widgets",
    "test:app": "npm run test --workspace=@create-studio/app",
    "test:admin": "npm run test --workspace=@create-studio/admin",
    "test:docs": "npm run test --workspace=@create-studio/docs",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.19.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^16.4.2"
  }
}
